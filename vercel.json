{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/command/pending",
      "dest": "index.js"
    },
    {
      "src": "/command",
      "dest": "index.js"
    },
    {
      "src": "/result/latest",
      "dest": "index.js"
    },
    {
      "src": "/result",
      "dest": "index.js"
    },
    {
      "src": "/status",
      "dest": "index.js"
    },
    {
      "src": "/heartbeat",
      "dest": "index.js"
    },
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ]
}